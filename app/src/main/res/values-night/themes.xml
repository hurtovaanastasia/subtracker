<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Subtracker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Основные цвета -->
        <item name="colorPrimary">@color/purple_300</item>
        <item name="colorPrimaryVariant">@color/purple_500</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Наши кастомные атрибуты -->
        <item name="colorBackground">@color/dark_background</item>
        <item name="colorSurface">@color/card_dark</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>

        <!-- Системные -->
        <item name="android:windowBackground">@color/dark_background</item>
        <item name="android:statusBarColor">@color/purple_800</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
    </style>
</resources>